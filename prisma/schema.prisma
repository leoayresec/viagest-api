generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  users           User[]
}

model Permission {
  id              String           @id @default(uuid())
  key             String           @unique
  description     String?
  group           String
  createdAt       DateTime         @default(now())
  rolePermissions RolePermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model User {
  id                String          @id @default(uuid())
  login             String          @unique
  password          String
  name              String
  active            Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  roleId            String
  role              Role            @relation(fields: [roleId], references: [id])
  records           ServiceRecord[] @relation("RecordUser")
  supervisedRecords ServiceRecord[] @relation("Supervisor")
  recordedRecords   ServiceRecord[] @relation("Recorder")
}

model State {
  id     String @id
  code   String @unique
  name   String
  active Boolean @default(false)
  cities City[]
}

model City {
  id            String         @id
  stateId       String
  name          String
  ibgeCode      String         @unique
  active        Boolean        @default(false)
  state         State          @relation(fields: [stateId], references: [id])
  neighborhoods Neighborhood[]

  @@index([stateId])
}

model Neighborhood {
  id     String @id @default(uuid())
  cityId String
  name   String
  city   City   @relation(fields: [cityId], references: [id])
  roads  Road[]

  @@unique([cityId, name])
  @@index([cityId])
}

model Road {
  id             String          @id @default(uuid())
  name           String
  lengthM        Float           @default(0)
  widthM         Float           @default(0)
  status         String          @default("ativa")
  neighborhoodId String
  neighborhood   Neighborhood    @relation(fields: [neighborhoodId], references: [id])
  records        ServiceRecord[]

  @@unique([neighborhoodId, name])
  @@index([neighborhoodId])
}

model ServiceRecord {
  id           String      @id @default(uuid())
  date         DateTime
  serviceType  ServiceType
  data         Json
  createdAt    DateTime    @default(now())
  userId       String?
  roadId       String?
  supervisorId String?
  recorderId   String?
  supervisor   User?       @relation("Supervisor", fields: [supervisorId], references: [id])
  recorder     User?       @relation("Recorder", fields: [recorderId], references: [id])
  road         Road?       @relation(fields: [roadId], references: [id])
  user         User?       @relation("RecordUser", fields: [userId], references: [id])

  @@index([date])
  @@index([roadId])
}

model SpreadsheetTemplate {
  id          String           @id @default(uuid())
  name        String
  description String?
  version     Int              @default(1)
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  mappings    FieldMapping[]
  imports     ImportHistory[]
  columns     TemplateColumn[]

  @@map("spreadsheet_templates")
}

model TemplateColumn {
  id              String              @id @default(uuid())
  templateId      String
  columnKey       String
  displayName     String
  expectedHeaders String[]
  dataType        String
  required        Boolean             @default(false)
  unique          Boolean             @default(false)
  defaultValue    String?
  unit            String?
  allowedValues   String[]
  weight          Int                 @default(0)
  sortOrder       Int                 @default(0)
  template        SpreadsheetTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  rules           ValidationRule[]

  @@map("template_columns")
}

model ValidationRule {
  id           String         @id @default(uuid())
  columnId     String
  ruleType     String
  ruleValue    String
  errorMessage String
  severity     String
  column       TemplateColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@map("validation_rules")
}

model FieldMapping {
  id            String              @id @default(uuid())
  templateId    String
  sourceColumn  String
  targetColumn  String
  transformRule String?
  isActive      Boolean             @default(true)
  template      SpreadsheetTemplate @relation(fields: [templateId], references: [id])

  @@map("field_mappings")
}

model ImportHistory {
  id           String              @id @default(uuid())
  templateId   String
  fileName     String
  fileType     String
  totalRows    Int
  importedRows Int
  errorRows    Int
  status       String
  importedAt   DateTime            @default(now())
  importedBy   String
  errors       ImportError[]
  template     SpreadsheetTemplate @relation(fields: [templateId], references: [id])
  dataRows     ImportedData[]

  @@map("import_histories")
}

model ImportError {
  id           String        @id @default(uuid())
  importId     String
  rowNumber    Int
  columnName   String?
  errorType    String
  errorMessage String
  rawValue     String?
  import       ImportHistory @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@map("import_errors")
}

model ImportedData {
  id        String        @id @default(uuid())
  importId  String
  data      Json
  rawData   Json?
  rowNumber Int
  valid     Boolean       @default(true)
  import    ImportHistory @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@map("imported_data")
}

enum ServiceType {
  limpeza
  obs_limpeza
  escavacao
  colchao_areia
  tubo
  manta_bidim
  aterro
  obs_drenagem
  motor
  pv
  bl
  obs_pvbl
  espinha_bl
  terrap
  obs_terrap
  subbase
  cbuq
  binder
  pintura_ligacao
  obs_pav
  tampao_70
  fresagem
  remendo_profundo
  obs_recuperacao
  demolicao_calcada
  demolicao_meiofio
  colchao_areia_meiofio
  demolicao_linha_agua
  linha_agua
  urb
  obs_urb
  urb_controle
  redes_auxiliares
  rede_domiciliar
  info_adicionais
}
